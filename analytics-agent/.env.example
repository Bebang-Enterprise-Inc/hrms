# BEI Analytics Agent — Environment Variables
# Copy to .env and fill in values before deployment
# DO NOT commit .env to git

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Meta Ads (required for sync script)
META_ACCESS_TOKEN=EAAx...

# Google credentials path (mounted via docker-compose volume)
GOOGLE_CREDENTIALS_PATH=/app/credentials/task-manager-service.json

# Claude CLI auth (Max subscription, $0/run)
# Generate with: claude setup-token
# Valid for 1 year, renew before expiry
CLAUDE_OAUTH_TOKEN=sk-ant-oat01-...
