[
    {
        "doctype": "Custom Field",
        "name": "Item-custom_shelf_life_days",
        "dt": "Item",
        "fieldname": "custom_shelf_life_days",
        "fieldtype": "Int",
        "label": "Shelf Life (Days)",
        "insert_after": "shelf_life_in_days",
        "description": "Product shelf life in days for expiry tracking"
    },
    {
        "doctype": "Custom Field",
        "name": "Item-custom_reorder_days",
        "dt": "Item",
        "fieldname": "custom_reorder_days",
        "fieldtype": "Int",
        "label": "Target Days Inventory",
        "insert_after": "custom_shelf_life_days",
        "description": "Target Days Inventory (DI) for this product. Default is 14 days."
    },
    {
        "doctype": "Custom Field",
        "name": "Item-custom_storage_temp_min",
        "dt": "Item",
        "fieldname": "custom_storage_temp_min",
        "fieldtype": "Float",
        "label": "Min Storage Temp (°C)",
        "insert_after": "custom_reorder_days",
        "description": "Minimum storage temperature in Celsius"
    },
    {
        "doctype": "Custom Field",
        "name": "Item-custom_storage_temp_max",
        "dt": "Item",
        "fieldname": "custom_storage_temp_max",
        "fieldtype": "Float",
        "label": "Max Storage Temp (°C)",
        "insert_after": "custom_storage_temp_min",
        "description": "Maximum storage temperature in Celsius"
    },
    {
        "doctype": "Custom Field",
        "name": "Item-custom_formula_variant",
        "dt": "Item",
        "fieldname": "custom_formula_variant",
        "fieldtype": "Select",
        "label": "Formula Variant",
        "options": "\nOriginal\nGriffith\nN/A",
        "insert_after": "custom_storage_temp_max",
        "description": "Formula variant for Frozen Milk (FG020) tracking"
    },
    {
        "doctype": "Custom Field",
        "name": "User-custom_is_pcf_custodian",
        "dt": "User",
        "fieldname": "custom_is_pcf_custodian",
        "fieldtype": "Check",
        "label": "Is PCF Custodian",
        "insert_after": "enabled",
        "description": "Can manage Petty Cash Fund batches"
    },
    {
        "doctype": "Custom Field",
        "name": "Warehouse-custom_pcf_enabled",
        "dt": "Warehouse",
        "fieldname": "custom_pcf_enabled",
        "fieldtype": "Check",
        "label": "PCF Enabled",
        "insert_after": "custom_area_supervisor",
        "description": "Whether this store uses PCF batch workflow"
    },
    {
        "doctype": "Custom Field",
        "name": "Warehouse-custom_area_supervisor",
        "dt": "Warehouse",
        "fieldname": "custom_area_supervisor",
        "fieldtype": "Link",
        "label": "Area Supervisor",
        "options": "User",
        "insert_after": "is_group",
        "description": "Area Supervisor responsible for this store"
    },
    {
        "doctype": "Custom Field",
        "name": "Employee-custom_nickname",
        "dt": "Employee",
        "fieldname": "custom_nickname",
        "fieldtype": "Data",
        "label": "Nickname",
        "insert_after": "employee_name",
        "description": "Searchable nickname (e.g., Bong for Edilberto)",
        "in_global_search": 1
    },
    {
        "doctype": "Custom Field",
        "name": "Employee-custom_government_id_photo",
        "dt": "Employee",
        "fieldname": "custom_government_id_photo",
        "fieldtype": "Attach Image",
        "label": "Government ID Photo",
        "insert_after": "image",
        "description": "Latest verified government ID for name verification"
    },
    {
        "doctype": "Custom Field",
        "name": "Employee-custom_enrichment_section",
        "dt": "Employee",
        "fieldname": "custom_enrichment_section",
        "fieldtype": "Section Break",
        "label": "Data Enrichment Status",
        "insert_after": "custom_government_id_photo",
        "collapsible": 1
    },
    {
        "doctype": "Custom Field",
        "name": "Employee-custom_enrichment_status",
        "dt": "Employee",
        "fieldname": "custom_enrichment_status",
        "fieldtype": "Select",
        "label": "Enrichment Status",
        "options": "Not Started\nIn Progress\nSubmitted\nComplete",
        "default": "Not Started",
        "insert_after": "custom_enrichment_section",
        "in_standard_filter": 1
    },
    {
        "doctype": "Custom Field",
        "name": "Employee-custom_enrichment_submitted_date",
        "dt": "Employee",
        "fieldname": "custom_enrichment_submitted_date",
        "fieldtype": "Date",
        "label": "Enrichment Submitted Date",
        "insert_after": "custom_enrichment_status",
        "read_only": 1
    },
    {
        "doctype": "Custom Field",
        "name": "Employee-custom_enrichment_complete_date",
        "dt": "Employee",
        "fieldname": "custom_enrichment_complete_date",
        "fieldtype": "Date",
        "label": "Enrichment Complete Date",
        "insert_after": "custom_enrichment_submitted_date",
        "read_only": 1
    },
    {
        "doctype": "Custom Field",
        "name": "Material Request-custom_store_order",
        "dt": "Material Request",
        "fieldname": "custom_store_order",
        "fieldtype": "Link",
        "options": "BEI Store Order",
        "label": "Store Order",
        "insert_after": "schedule_date",
        "description": "G-070: Link to the BEI Store Order that generated this Material Request"
    }
]
