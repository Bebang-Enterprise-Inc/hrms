{
  "name": "BEI Signed Document",
  "module": "HR",
  "doctype": "DocType",
  "engine": "InnoDB",
  "is_submittable": 0,
  "track_changes": 1,
  "autoname": "BEI-SIGN-.YYYY.-.#####",
  "naming_rule": "Expression",
  "fields": [
    {
      "fieldname": "document_title",
      "fieldtype": "Data",
      "label": "Document Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "template_name",
      "fieldtype": "Data",
      "label": "Template Name"
    },
    {
      "fieldname": "documenso_document_id",
      "fieldtype": "Data",
      "label": "Documenso Document ID",
      "unique": 1,
      "read_only": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nSent\nPartially Signed\nCompleted\nDeclined",
      "default": "Draft",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "completed_at",
      "fieldtype": "Datetime",
      "label": "Completed At",
      "read_only": 1
    },
    {
      "fieldname": "document_url",
      "fieldtype": "Data",
      "label": "Document URL",
      "read_only": 1
    },
    {
      "fieldname": "section_break_linked",
      "fieldtype": "Section Break",
      "label": "Linked Document"
    },
    {
      "fieldname": "linked_doctype",
      "fieldtype": "Link",
      "label": "Linked DocType",
      "options": "DocType"
    },
    {
      "fieldname": "linked_docname",
      "fieldtype": "Dynamic Link",
      "label": "Linked Document",
      "options": "linked_doctype"
    },
    {
      "fieldname": "section_break_signers",
      "fieldtype": "Section Break",
      "label": "Signers"
    },
    {
      "fieldname": "signers",
      "fieldtype": "Table",
      "label": "Signers",
      "options": "BEI Signed Document Signer"
    }
  ],
  "permissions": [
    {
      "role": "HR Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "HR User",
      "read": 1
    },
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
